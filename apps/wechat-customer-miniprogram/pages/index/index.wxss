.page {
  min-height: 100vh;
  background: #fffaf0;
  color: #273936;
}

.content {
  height: calc(100vh - 120rpx);
}

.screen {
  padding: 0 26rpx 150rpx;
}

.local-screen {
  min-height: calc(100vh - 120rpx);
  padding: 0 28rpx 150rpx;
  background: #edf3ef;
}

.home-hero {
  padding: 48rpx 20rpx 38rpx;
  text-align: center;
  background: #ffffff;
  margin: 0 -26rpx 8rpx;
}

.brand {
  display: block;
  color: #526a64;
  font-size: 30rpx;
  font-weight: 500;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  color: #172420;
  font-size: 42rpx;
  font-weight: 600;
  line-height: 1.25;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  color: #7a8a85;
  font-size: 27rpx;
}

.section {
  padding: 28rpx 0;
}

.section.first {
  padding-top: 44rpx;
}

.eyebrow {
  display: block;
  color: #72877f;
  font-size: 22rpx;
  letter-spacing: 5rpx;
  margin-bottom: 8rpx;
}

.section-title {
  display: block;
  color: #273936;
  font-size: 34rpx;
  font-weight: 400;
  line-height: 1.35;
  margin-bottom: 18rpx;
}

.topic-grid,
.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.topic-card,
.activity-card,
.blog-card,
.local-card,
.order-card,
.list-row,
.slot {
  background: #f7efe4;
  border: 1rpx solid rgba(39, 57, 54, 0.14);
  border-radius: 10rpx;
  overflow: hidden;
  box-sizing: border-box;
  text-align: left;
}

.topic-card image,
.activity-card image,
.blog-card image,
.image-placeholder {
  width: 100%;
  aspect-ratio: 1 / 1;
  display: block;
  background: linear-gradient(145deg, #79b8ad, #e4c86f 52%, #243b37);
}

.topic-card text {
  display: block;
  padding: 16rpx;
  color: #273936;
  font-size: 28rpx;
}

.activity-card {
  padding: 0;
  margin: 0;
}

.blog-card {
  padding: 0;
  margin: 0;
}

.activity-card::after,
.blog-card::after {
  border: 0;
}

.card-copy,
.local-card,
.order-card,
.list-row {
  padding: 18rpx;
}

.local-hero {
  position: relative;
  padding: 42rpx 10rpx 24rpx 92rpx;
}

.local-back {
  position: absolute;
  top: 40rpx;
  left: 16rpx;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 1rpx solid rgba(47, 104, 114, .22);
  border-radius: 50%;
  color: #526a64;
  background: rgba(255, 253, 246, .72);
  font-size: 46rpx;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(38, 57, 50, .08);
}

.local-hero-title {
  display: block;
  max-width: 560rpx;
  color: #1e3033;
  font-family: "Songti SC", "STSong", serif;
  font-size: 56rpx;
  font-weight: 400;
  line-height: 1.15;
}

.local-hero-copy {
  display: block;
  max-width: 560rpx;
  margin-top: 18rpx;
  color: #667873;
  font-size: 27rpx;
  line-height: 1.65;
}

.local-scene-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 236rpx 236rpx;
  gap: 16rpx;
  margin: 10rpx 0 34rpx;
}

.local-scene-card {
  position: relative;
  height: 100%;
  min-height: 0;
  margin: 0;
  padding: 0;
  overflow: hidden;
  border: 0;
  border-radius: 12rpx;
  background: #2f6872;
  text-align: left;
}

.local-scene-card::after {
  border: 0;
}

.local-scene-card.scene-0 {
  grid-row: 1 / span 2;
}

.local-scene-card image,
.local-scene-card .image-placeholder {
  width: 100%;
  height: 100%;
  display: block;
}

.local-scene-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(20, 31, 28, 0.05), rgba(20, 31, 28, 0.72));
}

.local-scene-copy {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 22rpx;
  color: #fffaf2;
}

.local-scene-copy text:first-child {
  display: block;
  font-family: "Songti SC", "STSong", serif;
  font-size: 37rpx;
  font-weight: 400;
  line-height: 1.18;
}

.local-scene-card.scene-0 .local-scene-copy text:first-child {
  font-size: 44rpx;
}

.local-scene-copy text:last-child {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 250, 242, 0.86);
  font-size: 22rpx;
  line-height: 1.45;
}

.local-upcoming-section,
.local-directory {
  padding-top: 20rpx;
}

.local-event-card {
  display: grid;
  grid-template-columns: 92rpx 1fr 100rpx;
  gap: 18rpx;
  align-items: center;
  width: 100%;
  min-height: 118rpx;
  margin: 0 0 14rpx;
  padding: 18rpx;
  border: 1rpx solid #d6ddd7;
  border-radius: 10rpx;
  color: #263330;
  background: #f8fbf7;
  text-align: left;
}

.local-event-card::after {
  border: 0;
}

.local-event-day {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  color: #8e7250;
  background: #efe6d5;
  font-size: 23rpx;
  line-height: 1.2;
  text-align: center;
}

.local-event-copy {
  min-width: 0;
}

.local-event-card image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
}

.local-directory-title {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.local-directory .small-button {
  min-width: 108rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.local-directory .local-card {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  gap: 18rpx;
  width: 100%;
  margin: 0 0 14rpx;
  padding: 0;
  background: #f8fbf7;
}

.local-directory .local-card::after {
  border: 0;
}

.local-directory .local-card image,
.local-card-placeholder {
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b8985;
  background: #e8ece9;
  font-size: 24rpx;
}

.local-directory .local-card view:last-child {
  min-width: 0;
  padding: 18rpx 18rpx 18rpx 0;
}

.local-info-detail {
  background: #edf3ef;
}

.local-info-detail-cover {
  width: 100%;
  height: 420rpx;
  display: block;
  margin-top: 24rpx;
  border-radius: 12rpx;
}

.local-info-detail-copy {
  margin-top: 20rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(39, 57, 54, 0.14);
  border-radius: 12rpx;
  background: #f8fbf7;
}

.article-detail-copy,
.guide-detail-copy {
  padding: 34rpx 0 150rpx;
}

.article-title {
  display: block;
  color: #1e3033;
  font-family: "Songti SC", "STSong", serif;
  font-size: 46rpx;
  font-weight: 400;
  line-height: 1.25;
  margin-bottom: 14rpx;
}

.article-detail-copy .share-button,
.guide-detail-copy .share-button {
  margin-top: 18rpx;
  margin-bottom: 24rpx;
}

.article-body-text {
  display: block;
  margin-top: 18rpx;
  color: #45514d;
  font-size: 29rpx;
  font-weight: 300;
  line-height: 1.85;
  white-space: pre-wrap;
}

.guide-detail-photo {
  width: 100%;
  aspect-ratio: 1 / 1;
  display: block;
  margin-top: 10rpx;
  border-radius: 12rpx;
}

.guide-detail-thumbs {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.guide-detail-thumbs image {
  width: 110rpx;
  height: 110rpx;
  flex: none;
  border-radius: 8rpx;
}

.local-fact {
  margin-top: 20rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #edf3ef;
}

.local-fact text:last-child {
  display: block;
  margin-top: 6rpx;
  color: #273936;
  font-size: 26rpx;
}

.item-title {
  display: block;
  color: #273936;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 400;
}

.section-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.inline-button,
.share-button {
  margin: 0;
  padding: 0 20rpx;
  height: 58rpx;
  line-height: 58rpx;
  border: 1rpx solid #d7d0c4;
  border-radius: 999rpx;
  color: #526a64;
  background: #fffaf0;
  font-size: 24rpx;
}

.inline-button::after,
.share-button::after {
  border: 0;
}

.home-review-scroll,
.guide-scroll {
  white-space: nowrap;
  margin: 0 -26rpx;
  padding-left: 26rpx;
}

.home-review-card {
  display: inline-block;
  width: 650rpx;
  margin-right: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #ded9cf;
  border-radius: 12rpx;
  background: #fffaf0;
  box-sizing: border-box;
  white-space: normal;
  vertical-align: top;
}

.home-review-head {
  display: grid;
  grid-template-columns: 72rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
}

.review-avatar {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 50%;
  background: #b7c0bc;
  color: #ffffff;
  text-align: center;
  font-size: 26rpx;
}

.review-name {
  display: block;
  color: #202825;
  font-size: 28rpx;
  font-weight: 600;
}

.review-stars {
  display: block;
  margin-top: 4rpx;
  color: #f2aa00;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.review-date {
  color: #9aa29f;
  font-size: 22rpx;
}

.home-review-text {
  display: -webkit-box;
  margin-top: 20rpx;
  color: #454c49;
  font-size: 27rpx;
  font-weight: 300;
  line-height: 1.72;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.home-review-card.expanded .home-review-text {
  display: block;
  max-height: 360rpx;
  overflow-y: auto;
}

.review-activity {
  display: block;
  margin-top: 14rpx;
  color: #55709f;
  font-size: 24rpx;
  font-weight: 600;
}

.home-review-images {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  margin-top: 16rpx;
}

.home-review-images button {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 8rpx;
  overflow: hidden;
  background: transparent;
}

.home-review-images button::after {
  border: 0;
}

.home-review-images image {
  display: block;
  width: 100%;
  height: 94rpx;
  border-radius: 8rpx;
}

.guide-card {
  display: inline-block;
  width: 300rpx;
  margin: 0 16rpx 0 0;
  padding: 0;
  overflow: hidden;
  border: 1rpx solid #ded9cf;
  border-radius: 12rpx;
  background: #f7efe4;
  text-align: left;
  white-space: normal;
  vertical-align: top;
}

.guide-card::after {
  border: 0;
}

.guide-card image,
.guide-placeholder {
  display: flex;
  width: 100%;
  aspect-ratio: 1 / 1;
  align-items: center;
  justify-content: center;
  background: #dfe8e3;
  color: #526a64;
  font-size: 28rpx;
}

.guide-card .item-title {
  padding: 18rpx 18rpx 0;
}

.guide-card .summary {
  padding: 0 18rpx 20rpx;
}

.summary,
.muted {
  display: block;
  color: #72817d;
  font-size: 25rpx;
  line-height: 1.55;
  margin-top: 10rpx;
}

.upcoming-scroll {
  white-space: nowrap;
}

.upcoming-card {
  display: inline-flex;
  width: 610rpx;
  min-height: 150rpx;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(39, 57, 54, 0.14);
  white-space: normal;
}

.avatar {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 50%;
  background: #d9d7ce;
  color: #273936;
  font-size: 26rpx;
  flex: none;
}

.upcoming-copy {
  flex: 1;
}

.list-row,
.local-card,
.order-card {
  width: 100%;
  margin-bottom: 16rpx;
}

.login-panel {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f7efe4;
  border-radius: 10rpx;
}

.small-button {
  margin: 0;
  min-width: 180rpx;
  height: 68rpx;
  line-height: 68rpx;
  color: #24798a;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 112rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  padding: 12rpx 22rpx 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 -8rpx 28rpx rgba(39, 57, 54, 0.08);
}

.tabbar button {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border-radius: 18rpx;
  background: transparent;
  color: #7b8a85;
  font-size: 25rpx;
}

.tabbar button.active {
  background: #fff3c7;
  color: #5d4c0e;
  border: 1rpx solid #d7b64c;
}

.detail {
  min-height: 100vh;
  padding-bottom: 130rpx;
}

.detail-header {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(39, 57, 54, 0.12);
  background: #fffaf0;
}

.detail-header text {
  max-width: 540rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
}

.back {
  position: absolute;
  left: 22rpx;
  width: 64rpx;
  height: 64rpx;
  line-height: 58rpx;
  padding: 0;
  background: transparent;
  color: #526a64;
  font-size: 54rpx;
}

.detail-body {
  height: calc(100vh - 222rpx);
  padding: 0 26rpx;
  box-sizing: border-box;
}

.detail-cover {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 10rpx;
  margin-top: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag-row text {
  padding: 8rpx 14rpx;
  background: #f7efe4;
  border-radius: 8rpx;
  color: #60736e;
  font-size: 23rpx;
}

.slot {
  width: 100%;
  margin: 14rpx 0 0;
  padding: 20rpx;
}

.slot.selected {
  border-color: #24798a;
  background: #edf6f4;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 26rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
}

.primary {
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 10rpx;
  background: #24798a;
  color: #ffffff;
  font-size: 30rpx;
}

.empty {
  padding: 28rpx;
  color: #7b8a85;
  font-size: 26rpx;
}

.toast-line {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 136rpx;
  padding: 18rpx 22rpx;
  border-radius: 10rpx;
  background: rgba(39, 57, 54, 0.9);
  color: #fffaf0;
  font-size: 25rpx;
  z-index: 10;
}
